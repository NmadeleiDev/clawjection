{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/NmadeleiDev/clawjection/main/schemas/result.schema.json",
  "title": "ClawJection Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "needs_user_action", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "installed_packages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "installed_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "followups": {
      "type": "array",
      "items": { "$ref": "#/$defs/followup" }
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "followup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "instruction"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "instruction": { "type": "string", "minLength": 1 },
        "blocking": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    }
  }
}
